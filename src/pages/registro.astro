---
import Layout from '../layouts/Layout.astro';
import { apiFetch, ApiError } from '../lib/api';
import { setSessionCookie } from '../lib/session';
import type { AuthResponse } from '../lib/types';

const ALLOWED_RETURN = ['/cuenta', '/checkout', '/checkout/success'];

let error: string | null = null;
let name = '';
let email = '';

const requestedReturn = Astro.url.searchParams.get('return_to') ?? '/checkout';
const safeReturn = ALLOWED_RETURN.includes(requestedReturn) ? requestedReturn : '/checkout';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  name = String(form.get('name') ?? '').trim();
  email = String(form.get('email') ?? '').trim();
  const password = String(form.get('password') ?? '');

  try {
    const data = await apiFetch<AuthResponse>('/auth/register', {
      method: 'POST',
      body: { name, email, password },
    });
    setSessionCookie(Astro.cookies, data.access_token);
    return Astro.redirect(safeReturn);
  } catch (e) {
    error = e instanceof ApiError ? e.message : 'No pudimos crear tu cuenta.';
  }
}
---

<Layout title="Crear cuenta · SPEI Scan">
  <section class="min-h-screen flex items-center justify-center px-4 py-32">
    <div class="w-full max-w-md">
      <div class="mb-8 text-center">
        <p class="eyebrow">Empieza ahora</p>
        <h1 class="display-h2 mt-3">Crea tu cuenta</h1>
      </div>

      <form method="POST" class="card p-7 space-y-5">
        {error && (
          <div class="rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm text-red-200">
            {error}
          </div>
        )}

        <label class="block">
          <span class="text-xs font-mono uppercase tracking-wider text-white/40">Nombre</span>
          <input
            type="text"
            name="name"
            value={name}
            required
            autocomplete="name"
            class="mt-2 w-full rounded-lg border border-brand-line bg-brand-ink/60 px-4 py-3 text-white placeholder-white/30 focus:border-brand-green focus:outline-none focus:ring-1 focus:ring-brand-green/40"
          />
        </label>

        <label class="block">
          <span class="text-xs font-mono uppercase tracking-wider text-white/40">Correo</span>
          <input
            type="email"
            name="email"
            value={email}
            required
            autocomplete="email"
            class="mt-2 w-full rounded-lg border border-brand-line bg-brand-ink/60 px-4 py-3 text-white placeholder-white/30 focus:border-brand-green focus:outline-none focus:ring-1 focus:ring-brand-green/40"
          />
        </label>

        <label class="block">
          <span class="text-xs font-mono uppercase tracking-wider text-white/40">Contraseña</span>
          <input
            type="password"
            name="password"
            required
            minlength="8"
            autocomplete="new-password"
            class="mt-2 w-full rounded-lg border border-brand-line bg-brand-ink/60 px-4 py-3 text-white placeholder-white/30 focus:border-brand-green focus:outline-none focus:ring-1 focus:ring-brand-green/40"
          />
          <span class="mt-1.5 block text-xs text-white/40">Mínimo 8 caracteres.</span>
        </label>

        <button type="submit" class="btn-primary w-full">Crear cuenta</button>

        <p class="text-center text-sm text-white/50">
          ¿Ya tienes cuenta?
          <a href={`/login?return_to=${encodeURIComponent(safeReturn)}`} class="text-brand-green hover:underline">Inicia sesión</a>
        </p>
      </form>
    </div>
  </section>
</Layout>
