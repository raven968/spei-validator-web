---
const navLinks = [
  { href: '/#como-funciona', label: 'Cómo funciona' },
  { href: '/#precios',       label: 'Precios' },
  { href: '/#contacto',      label: 'Contacto' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-brand-bg/90 backdrop-blur-md border-b border-white/10">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3">
      <img src="/logo.png" alt="SPEI Scan" class="h-8 w-auto" />
      <span class="font-bold text-lg text-white hidden sm:block">SPEI Scan</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="text-sm text-white/70 hover:text-brand-green transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/#precios"
        class="text-sm bg-brand-green text-brand-bg font-semibold px-4 py-2 rounded-lg hover:bg-brand-green/90 transition-colors"
      >
        Comenzar
      </a>
    </nav>

    <!-- Mobile menu button -->
    <button
      id="menu-btn"
      class="md:hidden p-2 text-white/70 hover:text-white"
      aria-label="Abrir menú"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6"  x2="21" y2="6"  />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden md:hidden bg-brand-surface border-t border-white/10 px-4 py-4">
    <nav class="flex flex-col gap-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="text-sm text-white/70 hover:text-brand-green transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/#precios"
        class="text-sm bg-brand-green text-brand-bg font-semibold px-4 py-2 rounded-lg text-center hover:bg-brand-green/90 transition-colors"
      >
        Comenzar
      </a>
    </nav>
  </div>
</header>

<script>
  const btn  = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  // Close mobile menu when a nav link is clicked
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => menu.classList.add('hidden'));
  });
</script>
