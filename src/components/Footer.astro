---
const year = new Date().getFullYear();
---

<footer class="bg-brand-surface border-t border-white/10 mt-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">

      <!-- Brand -->
      <div class="flex items-center gap-3">
        <img src="/logo.png" alt="SPEI Scan" class="h-8 w-auto" />
        <span class="font-bold text-white">SPEI Scan</span>
      </div>

      <!-- Links -->
      <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-white/50">
        <a href="/#como-funciona" class="hover:text-white transition-colors">Cómo funciona</a>
        <a href="/#precios"       class="hover:text-white transition-colors">Precios</a>
        <a href="/#contacto"      class="hover:text-white transition-colors">Contacto</a>
        <a href="/terminos"       class="hover:text-white transition-colors">Términos y Condiciones</a>
        <a href="/privacidad"     class="hover:text-white transition-colors">Política de Privacidad</a>
      </nav>
    </div>

    <div class="mt-8 pt-8 border-t border-white/10 text-center text-sm text-white/30">
      &copy; {year} SPEI Scan. Todos los derechos reservados.
    </div>
  </div>
</footer>
