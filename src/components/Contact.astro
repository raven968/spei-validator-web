<section id="contacto" class="py-24 bg-brand-surface">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="max-w-2xl mx-auto text-center">

      <span class="text-brand-green text-sm font-semibold uppercase tracking-widest">Contacto</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-white">¿Tienes preguntas?</h2>
      <p class="mt-4 text-white/60 text-lg">
        Estamos aquí para ayudarte. Escríbenos y te respondemos a la brevedad.
      </p>

      <div class="mt-10 flex items-center justify-center">
        <a
          href="mailto:soporte@speivalidator.com"
          class="flex items-center gap-3 bg-brand-bg border border-white/10 hover:border-brand-green/40 text-white px-8 py-4 rounded-xl transition-all hover:scale-105 active:scale-100 group"
        >
          <svg class="w-5 h-5 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          <span class="font-medium">soporte@speivalidator.com</span>
        </a>
      </div>

      <p class="mt-6 text-white/30 text-sm">
        Tiempo de respuesta: menos de 24 horas en días hábiles.
      </p>
    </div>
  </div>
</section>
