---
const steps = [
  {
    number: '01',
    title: 'Sube el comprobante',
    description:
      'Toma una foto o selecciona desde tu galería la imagen del comprobante SPEI que deseas verificar.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
    </svg>`,
  },
  {
    number: '02',
    title: 'IA extrae y analiza los datos',
    description:
      'Gemini Vision lee el comprobante, extrae monto, banco, clave de rastreo y fecha, y detecta posibles alteraciones.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
    </svg>`,
  },
  {
    number: '03',
    title: 'Verificación oficial en Banxico',
    description:
      'Consultamos el portal CEP de Banxico en tiempo real para confirmar si la transferencia existe en el registro oficial.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
    </svg>`,
  },
];
---

<section id="como-funciona" class="py-24 bg-brand-surface">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="text-center mb-16">
      <span class="text-brand-green text-sm font-semibold uppercase tracking-widest">Proceso</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-white">¿Cómo funciona?</h2>
      <p class="mt-4 text-white/60 text-lg max-w-xl mx-auto">
        En tres pasos simples sabrás si un comprobante SPEI es auténtico.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid md:grid-cols-3 gap-6 relative">
      {steps.map((step, i) => (
        <div class="relative bg-brand-bg rounded-2xl p-8 border border-white/10 hover:border-brand-green/30 transition-colors group">

          <!-- Background step number -->
          <span class="absolute top-6 right-6 text-5xl font-black text-white/5 group-hover:text-white/10 transition-colors select-none">
            {step.number}
          </span>

          <!-- Icon -->
          <div class="w-14 h-14 bg-brand-green/10 rounded-xl flex items-center justify-center text-brand-green mb-6">
            <Fragment set:html={step.icon} />
          </div>

          <!-- Content -->
          <h3 class="text-xl font-bold text-white mb-3">{step.title}</h3>
          <p class="text-white/60 leading-relaxed text-sm">{step.description}</p>

          <!-- Arrow connector (desktop only, not on last item) -->
          {i < steps.length - 1 && (
            <div class="hidden md:flex absolute -right-3 top-1/2 -translate-y-1/2 z-10 w-6 h-6 items-center justify-center text-brand-green/40">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
