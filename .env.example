# URL pública del API Laravel (visible al cliente; usado solo si se hace fetch desde el browser)
PUBLIC_API_URL=http://localhost:8000/v1

# URL del API que usa Astro server-side (puede ser interna en producción)
API_URL_INTERNAL=http://localhost:8000/v1

# URL pública del propio frontend (para construir success_url/cancel_url de Stripe)
WEB_URL=http://localhost:4321
