---
import Layout from '../layouts/Layout.astro';
import { apiFetch } from '../lib/api';
import { setSessionCookie } from '../lib/session';
import type { AuthResponse } from '../lib/types';

const ALLOWED_RETURN = ['/cuenta', '/checkout', '/checkout/success'];

const ott = Astro.url.searchParams.get('ott');
const requestedReturnTo = Astro.url.searchParams.get('return_to') ?? '/cuenta';

let error: string | null = null;

if (!ott) {
  error = 'Falta el token de acceso.';
} else {
  try {
    const data = await apiFetch<AuthResponse>('/auth/consume-ott', {
      method: 'POST',
      body: { token: ott },
    });

    setSessionCookie(Astro.cookies, data.access_token, data.expires_in ?? 3600);

    const target = ALLOWED_RETURN.includes(data.return_to ?? '')
      ? (data.return_to as string)
      : ALLOWED_RETURN.includes(requestedReturnTo)
        ? requestedReturnTo
        : '/cuenta';

    return Astro.redirect(target);
  } catch (e) {
    error = e instanceof Error ? e.message : 'No pudimos iniciar tu sesión.';
  }
}
---

<Layout title="Iniciando sesión · SPEI Scan">
  <section class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-md rounded-2xl border border-brand-line bg-brand-surface/60 p-8 backdrop-blur-sm">
      <h1 class="font-display text-2xl text-white mb-3">No pudimos iniciarte sesión</h1>
      <p class="text-white/60 mb-6 text-sm">{error}</p>
      <p class="text-white/45 text-sm mb-6">
        El enlace pudo haber expirado o ya se utilizó. Vuelve a tu app y solicita un nuevo enlace.
      </p>
      <a href="/login" class="btn-primary w-full text-center block">Iniciar sesión manualmente</a>
    </div>
  </section>
</Layout>
